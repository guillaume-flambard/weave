# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://weave:weave@localhost:5433/weave

# API bind address
WEAVE_API_ADDR=127.0.0.1:8787

# Optional API auth (mutating routes). When unset, API is open (dev only).
# WEAVE_API_KEY=

# Required — encrypts OAuth tokens at rest (ChaCha20-Poly1305).
# Generate: openssl rand -base64 32
WEAVE_ENC_KEY=

# Web app URL (OAuth redirects). Default: http://localhost:3200
WEAVE_WEB_URL=http://localhost:3200

# CORS — comma-separated origins, or WEAVE_CORS_ALLOW_ANY=true for local demos
# WEAVE_CORS_ORIGIN=http://localhost:3200,http://127.0.0.1:3200

# LLM gateway — multi-provider, pluggable.
# WEAVE_LLM_PROVIDER = ollama | groq | claude | heuristic | auto | openai
WEAVE_LLM_PROVIDER=groq

# --- Groq (recommended for fast cloud inference) ---
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Fast extraction during simulation; use llama-3.3-70b-versatile for higher quality Q&A
GROQ_MODEL=llama-3.1-8b-instant

# Embeddings — Groq has no embedding API in Weave; use hash (deterministic, offline).
WEAVE_EMBED_PROVIDER=hash

# --- Ollama (local, no key) ---
# WEAVE_LLM_PROVIDER=ollama
# WEAVE_OLLAMA_URL=http://localhost:11434
# WEAVE_OLLAMA_MODEL=qwen3.5:9b
# WEAVE_EMBED_PROVIDER=ollama
# WEAVE_EMBED_MODEL=nomic-embed-text

# Claude (used when provider=claude, or provider=auto with a key present)
ANTHROPIC_API_KEY=
WEAVE_LLM_MODEL=claude-opus-4-8

# OpenAI-compatible (provider=openai, or legacy groq via OPENAI_*)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Pattern -> Skill materialization threshold (occurrences)
WEAVE_SKILL_THRESHOLD=5

# --- Connectors (real ingest) ---

# --- Slack OAuth (multi-tenant user token) ---
# Create app at https://api.slack.com/apps — user scopes: channels:history, channels:read
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
# Redirect URI: {WEAVE_WEB_URL}/weave-api/oauth/slack/callback (prod: https://strayeye.com/weave-api/...)

# --- Notion OAuth ---
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# Redirect URI: {WEAVE_WEB_URL}/weave-api/oauth/notion/callback

# Discord (OAuth bot-install; one Weave-owned app). Message Content Intent must be ON.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
# Redirect URI: {WEAVE_WEB_URL}/weave-api/oauth/discord/callback (proxied to the API, matches Slack/Notion)
DISCORD_REDIRECT_URI=https://strayeye.com/weave-api/oauth/discord/callback
# Optional: DISCORD_API_BASE, DISCORD_MAX_CHANNELS, DISCORD_MAX_MESSAGES

# Legacy env-token fallbacks (dev / import only — prefer OAuth)
# Create a bot at https://api.slack.com/apps, grant scopes: channels:history, groups:history, users:read
# Unset → /ingest/slack returns {status:"not_configured"} (no ingest).
SLACK_BOT_TOKEN=
SLACK_CHANNEL=

# Notion connector (real ingest, pages + databases)
# Create an internal integration at https://www.notion.so/my-integrations,
# copy its token, and share the target pages/databases with the integration.
# Unset → the demo replays scripted Notion seed events instead.
NOTION_TOKEN=
# Optional: restrict to specific object ids (comma-separated). Empty = everything shared.
NOTION_PAGE_IDS=
NOTION_DATABASE_IDS=
