# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://weave:weave@localhost:5433/weave

# API bind address
WEAVE_API_ADDR=127.0.0.1:8787

# LLM gateway — multi-provider, pluggable.
# WEAVE_LLM_PROVIDER = ollama | groq | claude | heuristic | auto | openai
WEAVE_LLM_PROVIDER=groq

# --- Groq (recommended for fast cloud inference) ---
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Fast extraction during simulation; use llama-3.3-70b-versatile for higher quality Q&A
GROQ_MODEL=llama-3.1-8b-instant

# Embeddings — Groq has no embedding API in Weave; use hash (deterministic, offline).
WEAVE_EMBED_PROVIDER=hash

# --- Ollama (local, no key) ---
# WEAVE_LLM_PROVIDER=ollama
# WEAVE_OLLAMA_URL=http://localhost:11434
# WEAVE_OLLAMA_MODEL=qwen3.5:9b
# WEAVE_EMBED_PROVIDER=ollama
# WEAVE_EMBED_MODEL=nomic-embed-text

# Claude (used when provider=claude, or provider=auto with a key present)
ANTHROPIC_API_KEY=
WEAVE_LLM_MODEL=claude-opus-4-8

# OpenAI-compatible (provider=openai, or legacy groq via OPENAI_*)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Pattern -> Skill materialization threshold (occurrences)
WEAVE_SKILL_THRESHOLD=5
